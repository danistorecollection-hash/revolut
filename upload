    <script>
        // ===== PAGE NAVIGATION - FIXED =====
        function goToPage(pageId) {
            console.log('Going to page:', pageId);
            
            // Close all popups
            document.querySelectorAll('.popup-overlay').forEach(el => {
                el.classList.remove('active');
            });
            
            // Hide ALL pages
            document.querySelectorAll('.page-section').forEach(el => {
                el.classList.remove('active');
                el.style.display = 'none';
            });
            
            // Show target page
            const target = document.getElementById(pageId);
            if (target) {
                target.classList.add('active');
                target.style.display = 'block';
                console.log('Page shown:', pageId);
            } else {
                console.error('Page not found:', pageId);
            }
            
            window.scrollTo(0, 0);
        }

        // ===== CONFIRM AND PROCEED =====
        function confirmAndProceed() {
            closePopup();
            goToPage('details-page');
        }

        // ===== COUNTRY CODE =====
        function updateCountryCode() {
            const select = document.getElementById('country-select');
            const code = select.value;
            document.getElementById('country-code').textContent = code || '+359';
        }

        // ===== INPUT RESTRICTIONS =====
        function onlyDigits(e) {
            return e.charCode >= 48 && e.charCode <= 57;
        }
        function onlyDigitsSlash(e) {
            return (e.charCode >= 48 && e.charCode <= 57) || e.charCode === 47;
        }

        // ===== PHONE VALIDATION =====
        function validatePhone(input) {
            input.value = input.value.replace(/\D/g, '');
            const error = document.getElementById('phone-error');
            if(input.value.length < 7) {
                input.classList.add('error');
                error.classList.add('show');
            } else {
                input.classList.remove('error');
                error.classList.remove('show');
            }
        }

        // ===== CONFIRM POPUP =====
        function showConfirmPopup() {
            const phone = document.getElementById('phone-input').value;
            const code = document.getElementById('country-code').textContent;
            
            if(phone.length < 7) {
                document.getElementById('phone-error').classList.add('show');
                document.getElementById('phone-input').classList.add('error');
                return;
            }
            
            document.getElementById('confirm-phone-text').textContent = code + ' ' + phone;
            document.getElementById('confirm-popup').classList.add('active');
        }

        function closePopup() {
            document.getElementById('confirm-popup').classList.remove('active');
        }

        // ===== SUCCESS POPUP =====
        function showSuccessPopup() {
            document.getElementById('success-popup').classList.add('active');
        }

        function closeSuccessPopup() {
            document.getElementById('success-popup').classList.remove('active');
            goToPage('home-page');
        }

        // ===== NAME VALIDATION =====
        function validateName(input) {
            const error = document.getElementById('name-error');
            if(input.value.trim().length < 2) {
                input.classList.add('error');
                error.classList.add('show');
            } else {
                input.classList.remove('error');
                error.classList.remove('show');
            }
            updateCardHolder();
        }

        // ===== EMAIL VALIDATION =====
        function validateEmail(input) {
            const error = document.getElementById('email-error');
            const email = input.value.trim();
            const hasAt = email.includes('@');
            const hasDot = email.includes('.', email.indexOf('@') + 1);
            
            if(!hasAt || !hasDot || email.indexOf('@') === 0 || email.indexOf('@') === email.length - 1) {
                input.classList.add('error');
                error.classList.add('show');
                return false;
            } else {
                input.classList.remove('error');
                error.classList.remove('show');
                return true;
            }
        }

        // ===== DOB VALIDATION =====
        function validateDOB(input) {
            const error = document.getElementById('dob-error');
            if(!input.value) {
                error.classList.add('show');
                return;
            }
            const dob = new Date(input.value);
            const today = new Date();
            let age = today.getFullYear() - dob.getFullYear();
            const monthDiff = today.getMonth() - dob.getMonth();
            if(monthDiff < 0 || (monthDiff === 0 && today.getDate() < dob.getDate())) {
                age--;
            }
            if(age < 18) {
                input.classList.add('error');
                error.classList.add('show');
            } else {
                input.classList.remove('error');
                error.classList.remove('show');
            }
        }

        // ===== VALIDATE DETAILS PAGE =====
        function validateDetails() {
            const name = document.getElementById('full-name');
            const email = document.getElementById('email');
            const dob = document.getElementById('dob');
            const postal = document.getElementById('postal');
            
            let valid = true;
            
            if(name.value.trim().length < 2) {
                name.classList.add('error');
                document.getElementById('name-error').classList.add('show');
                valid = false;
            }
            
            if(!validateEmail(email)) valid = false;
            
            if(!dob.value) {
                dob.classList.add('error');
                document.getElementById('dob-error').classList.add('show');
                valid = false;
            }
            
            if(postal.value && !/^\d+$/.test(postal.value)) {
                postal.classList.add('error');
                document.getElementById('postal-error').classList.add('show');
                valid = false;
            }
            
            if(valid) {
                goToPage('card-page');
                updateCardHolder();
            }
        }

        // ===== CARD NUMBER FORMATTING =====
        function formatCardNumber(input) {
            let value = input.value.replace(/\D/g, '');
            value = value.substring(0, 16);
            input.value = value.replace(/(\d{4})(?=\d)/g, '$1 ');
            
            const display = document.getElementById('card-display');
            if(value.length === 0) {
                display.textContent = '____ ____ ____ ____';
            } else {
                let displayText = '';
                for(let i = 0; i < 16; i++) {
                    if(i < value.length) {
                        displayText += value[i];
                    } else {
                        displayText += '_';
                    }
                    if((i + 1) % 4 === 0 && i !== 15) {
                        displayText += ' ';
                    }
                }
                display.textContent = displayText;
            }
            
            const error = document.getElementById('card-error');
            if(value.length > 0 && value.length !== 16) {
                input.classList.add('error');
                error.classList.add('show');
            } else {
                input.classList.remove('error');
                error.classList.remove('show');
            }
        }

        // ===== EXPIRY FORMATTING =====
        function formatExpiry(input) {
            let value = input.value.replace(/\D/g, '');
            if(value.length >= 2) {
                value = value.substring(0, 4);
                value = value.substring(0, 2) + '/' + value.substring(2);
            }
            input.value = value;
            
            document.getElementById('card-expiry').textContent = value || 'MM/YY';
            
            const error = document.getElementById('expiry-error');
            const parts = value.split('/');
            if(parts.length === 2 && parts[0].length === 2 && parts[1].length === 2) {
                const month = parseInt(parts[0]);
                const year = parseInt(parts[1]);
                const currentYear = new Date().getFullYear() % 100;
                const currentMonth = new Date().getMonth() + 1;
                
                if(month < 1 || month > 12) {
                    input.classList.add('error');
                    error.textContent = 'Month must be 01-12';
                    error.classList.add('show');
                } else if(year < currentYear || (year === currentYear && month < currentMonth)) {
                    input.classList.add('error');
                    error.textContent = 'Card has expired';
                    error.classList.add('show');
                } else {
                    input.classList.remove('error');
                    error.classList.remove('show');
                }
            }
        }

        // ===== CVC VALIDATION =====
        function validateCVC(input) {
            let value = input.value.replace(/\D/g, '');
            value = value.substring(0, 3);
            input.value = value;
            
            const error = document.getElementById('cvc-error');
            if(value.length > 0 && value.length !== 3) {
                input.classList.add('error');
                error.classList.add('show');
            } else {
                input.classList.remove('error');
                error.classList.remove('show');
            }
        }

        // ===== CARD TYPE SELECTION =====
        function selectCardType(el, type) {
            document.querySelectorAll('.card-badge').forEach(b => b.classList.remove('active'));
            el.classList.add('active');
        }

        // ===== UPDATE CARD LOGO =====
        function updateCardLogo() {
            document.getElementById('card-logo').textContent = document.getElementById('card-type-select').value;
        }

        // ===== UPDATE CARD HOLDER =====
        function updateCardHolder() {
            const name = document.getElementById('full-name').value.trim() || 'YOUR NAME';
            document.getElementById('card-holder').textContent = name.toUpperCase();
        }

        // ===== VALIDATE CARD PAGE =====
        function validateCard() {
            const cardNum = document.getElementById('card-number');
            const expiry = document.getElementById('expiry');
            const cvc = document.getElementById('cvc');
            
            let valid = true;
            
            const cleanNum = cardNum.value.replace(/\s/g, '');
            if(cleanNum.length !== 16) {
                cardNum.classList.add('error');
                document.getElementById('card-error').classList.add('show');
                valid = false;
            }
            
            if(expiry.value.length !== 5) {
                expiry.classList.add('error');
                document.getElementById('expiry-error').classList.add('show');
                valid = false;
            }
            
            if(cvc.value.length !== 3) {
                cvc.classList.add('error');
                document.getElementById('cvc-error').classList.add('show');
                valid = false;
            }
            
            if(valid) {
                showSuccessPopup();
            }
        }

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('bg-revolut-dark/95');
            } else {
                navbar.classList.remove('bg-revolut-dark/95');
            }
        });
    </script>
</body>
</html>