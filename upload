            font-weight: 700;
            margin-bottom: 8px;
            color: #fff;
        }
        .form-header p {
            color: rgba(255,255,255,0.6);
            font-size: 14px;
        }
        .progress-bar {
            display: flex;
            gap: 8px;
            margin-bottom: 32px;
            justify-content: center;
        }
        .progress-dot {
            width: 32px;
            height: 4px;
            border-radius: 2px;
            background: rgba(255,255,255,0.1);
            transition: all 0.3s;
        }
        .progress-dot.active {
            background: linear-gradient(135deg, #0075EB, #8B5CF6);
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: rgba(255,255,255,0.7);
            margin-bottom: 8px;
        }
        .form-group input,
        .form-group select {
            width: 100%;
            padding: 14px 16px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.15);
            background: rgba(255,255,255,0.08);
            color: #fff;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s;
            outline: none;
        }
        .form-group input:focus,
        .form-group select:focus {
            border-color: #0075EB;
            box-shadow: 0 0 0 3px rgba(0,117,235,0.15);
            background: rgba(255,255,255,0.12);
        }
        .form-group input::placeholder {
            color: rgba(255,255,255,0.3);
        }
        .form-group input.error {
            border-color: #ef4444;
        }
        .error-msg {
            color: #ef4444;
            font-size: 12px;
            margin-top: 6px;
            display: none;
        }
        .error-msg.show {
            display: block;
        }
        .phone-row {
            display: flex;
            gap: 12px;
        }
        .country-select-wrapper {
            position: relative;
            flex: 1;
        }
        .country-select-wrapper select {
            appearance: none;
            padding-right: 30px;
            cursor: pointer;
        }
        .country-select-wrapper::after {
            content: '▼';
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 10px;
            color: rgba(255,255,255,0.5);
            pointer-events: none;
        }
        .country-code-display {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 12px;
            padding: 14px 16px;
            min-width: 70px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            color: #0075EB;
            font-size: 15px;
        }
        .continue-btn {
            width: 100%;
            padding: 16px;
            border-radius: 12px;
            border: none;
            background: linear-gradient(135deg, #0075EB, #8B5CF6);
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 8px;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(0,117,235,0.3);
        }
        .continue-btn:hover {
            opacity: 0.9;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(0,117,235,0.4);
        }

        /* ===== POPUP ===== */
        .popup-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(12px);
            z-index: 3000;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .popup-overlay.active {
            display: flex;
        }
        .popup-box {
            background: rgba(20, 20, 40, 0.98);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 32px;
            max-width: 400px;
            width: 100%;
            text-align: center;
            animation: popupIn 0.3s ease;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }
        @keyframes popupIn {
            from { opacity: 0; transform: scale(0.95); }
            to { opacity: 1; transform: scale(1); }
        }
        .popup-box h3 {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 16px;
            color: #fff;
        }
        .popup-box p {
            color: rgba(255,255,255,0.7);
            font-size: 16px;
            margin-bottom: 28px;
        }
        .popup-buttons {
            display: flex;
            gap: 12px;
        }
        .popup-btn {
            flex: 1;
            padding: 14px;
            border-radius: 12px;
            border: none;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }
        .popup-btn.cancel {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,0.15);
        }
        .popup-btn.cancel:hover {
            background: rgba(255,255,255,0.15);
        }
        .popup-btn.confirm {
            background: linear-gradient(135deg, #0075EB, #8B5CF6);
            color: #fff;
        }
        .popup-btn.confirm:hover {
            opacity: 0.9;
            transform: translateY(-1px);
        }

        /* ===== SUCCESS POPUP ===== */
        .success-popup-box {
            background: rgba(20, 20, 40, 0.98);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 24px;
            padding: 48px;
            max-width: 500px;
            width: 100%;
            text-align: center;
            animation: popupIn 0.5s ease;
            box-shadow: 0 25px 50px rgba(0,0,0,0.5);
        }
        .success-icon {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, #00D4AA, #0075EB);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 24px;
            font-size: 36px;
            animation: successPop 0.5s ease;
            box-shadow: 0 10px 30px rgba(0,212,170,0.3);
        }
        @keyframes successPop {
            0% { transform: scale(0); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }
        .success-popup-box h2 {
            font-size: 28px;
            font-weight: 800;
            margin-bottom: 16px;
            color: #fff;
        }
        .success-popup-box p {
            color: rgba(255,255,255,0.7);
            font-size: 16px;
            line-height: 1.7;
            margin-bottom: 32px;
        }
        .got-it-btn {
            background: linear-gradient(135deg, #0075EB, #8B5CF6);
            color: #fff;
            padding: 16px 48px;
            border-radius: 32px;
            font-size: 16px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(0,117,235,0.3);
        }
        .got-it-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0,117,235,0.4);
        }

        /* ===== BONUS BADGE ===== */
        .bonus-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: linear-gradient(135deg, #0075EB, #8B5CF6);
            padding: 8px 20px;
            border-radius: 24px;
            font-size: 13px;
            font-weight: 600;
            margin-bottom: 24px;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(0,117,235,0.4); }
            50% { box-shadow: 0 0 0 10px rgba(0,117,235,0); }
        }

        /* ===== CARD PREVIEW ===== */
        .card-preview {
            width: 100%;
            max-width: 360px;
            height: 220px;
            margin: 0 auto 28px;
            position: relative;
            border-radius: 20px;
            padding: 28px;
            overflow: hidden;
            background: linear-gradient(135deg, #0ea5e9 0%, #3b82f6 30%, #1d4ed8 60%, #1e3a8a 100%);
            border: 1px solid rgba(59, 130, 246, 0.4);
            box-shadow: 0 20px 60px rgba(59, 130, 246, 0.3), 0 0 0 1px rgba(255,255,255,0.1);
            font-family: 'Courier New', monospace;
        }
        .card-preview::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -20%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 60%);
            border-radius: 50%;
        }
        .card-preview::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(14, 165, 233, 0.2) 0%, transparent 60%);
            border-radius: 50%;
        }
        .card-shine-effect {
            position: absolute;
            top: 0;
            left: -100%;
            width: 60%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
            transition: left 0.8s ease;
            z-index: 5;
            pointer-events: none;
        }
        .card-preview:hover .card-shine-effect {
            left: 150%;
        }
        .card-top-line {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #0ea5e9, #3b82f6, #8b5cf6, #0ea5e9);
            z-index: 2;
        }
        .card-chip-gold {
            width: 44px;
            height: 32px;
            background: linear-gradient(135deg, #d4af37 0%, #f4d03f 30%, #d4af37 60%, #b8860b 100%);
            border-radius: 8px;
            margin-bottom: 28px;
            position: relative;
            z-index: 2;
            box-shadow: 0 2px 8px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.3);
            border: 1px solid rgba(255,215,0,0.3);
        }
        .card-chip-gold::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 10%;
            right: 10%;
            height: 1px;
            background: rgba(0,0,0,0.2);
            transform: translateY(-50%);
        }
        .card-chip-gold::after {
            content: '';
            position: absolute;
            left: 50%;
            top: 15%;
            bottom: 15%;
            width: 1px;
            background: rgba(0,0,0,0.2);
            transform: translateX(-50%);
        }
        .card-chip-inner-gold {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 60%;
            height: 40%;
            border: 1px solid rgba(0,0,0,0.15);
            border-radius: 4px;
        }
        .card-number-display {
            font-size: 22px;
            letter-spacing: 3px;
            margin-bottom: 28px;
            position: relative;
            z-index: 2;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
            font-weight: 500;
            color: rgba(255,255,255,0.95);
            min-height: 28px;
        }
        .card-bottom-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            position: relative;
            z-index: 2;
        }
        .card-label-small {
            font-size: 9px;
            text-transform: uppercase;
            opacity: 0.6;
            margin-bottom: 4px;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.8);
        }
        .card-value-small {
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 1.5px;
            color: rgba(255,255,255,0.95);
        }
        .card-logo-area {
            text-align: right;
        }
        .card-logo-text {
            font-size: 20px;
            font-weight: 800;
            font-style: italic;
            letter-spacing: 1px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.3);
            color: rgba(255,255,255,0.95);
            line-height: 1;
        }
        .card-expiry-area {
            margin-bottom: 4px;
        }
        .card-expiry-label-small {
            font-size: 8px;
            text-transform: uppercase;
            opacity: 0.5;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.7);
            margin-bottom: 2px;
        }
        .card-expiry-value-small {
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.95);
        }
        .card-contactless-icon {
            position: absolute;
            top: 28px;
            right: 28px;
            width: 22px;
            height: 22px;
            z-index: 2;
            opacity: 0.5;
        }
        .card-contactless-icon svg {
            width: 100%;
            height: 100%;
            fill: rgba(255,255,255,0.9);
        }

        /* Card Badges */
        .card-badges {
            display: flex;
            gap: 12px;
            justify-content: center;
            margin-bottom: 24px;
        }
        .card-badge {
            padding: 10px 24px;
            border-radius: 24px;
            font-size: 13px;
            font-weight: 700;
            border: 2px solid transparent;
            cursor: pointer;
            transition: all 0.3s;
            letter-spacing: 0.5px;
        }
        .card-badge.vip {
            background: linear-gradient(135deg, rgba(255,215,0,0.15), rgba(255,215,0,0.05));
            border-color: rgba(255,215,0,0.4);
            color: #ffd700;
        }
        .card-badge.vip.active {
            background: linear-gradient(135deg, #ffd700, #ffb700);
            color: #1a1a2e;
            box-shadow: 0 0 25px rgba(255,215,0,0.3);
        }
        .card-badge.premium {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.2);
            color: rgba(255,255,255,0.7);
        }
        .card-badge.premium:hover {
            border-color: rgba(255,255,255,0.4);
            color: #fff;
        }
        .card-badge.premium.active {
            background: linear-gradient(135deg, #e2e8f0, #94a3b8);
            color: #1e293b;
            box-shadow: 0 0 25px rgba(148,163,184,0.3);
        }
        .card-inputs {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr;
            gap: 12px;
        }
    </style>
</head>
